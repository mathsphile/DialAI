{
  "name": "dialai",
  "version": "1.0.0",
  "description": "DialAI – General Purpose Voice AI Assistant powered by ElevenLabs + Exotel",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "setup-agent": "node scripts/setupAgent.js",
    "test:call": "node scripts/testScenarios.js",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "voice-ai",
    "elevenlabs",
    "exotel",
    "helpline",
    "conversational-ai"
  ],
  "author": "DialAI",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "winston": "^3.13.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "nodemon": "^3.1.4"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "js,json",
    "ignore": [
      "src/**/*.test.js"
    ],
    "delay": 500
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
